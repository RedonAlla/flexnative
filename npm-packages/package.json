{
  "name": "ra-framework",
  "private": true,
  "workspaces": [
    "src/packages/*",
    "src/packages/components/*",
    "src/packages/context/*",
    "src/packages/services/*",
    "src/shared/*"
  ],
  "version": "0.0.1",
  "description": "React Native Framework",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc --build",
    "clean": "npm run clean -ws",
    "lint": "eslint .",
    "format": "prettier --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "changeset publish",
    "validate": "npm run clean && npm run build"
  },
  "keywords": [
    "react",
    "react-native",
    "expo",
    "framework"
  ],
  "author": "Redon Alla",
  "license": "MIT",
  "dependencies": {
    "@flexnative/authentication": "^0.0.3",
    "expo": "^53.0.19",
    "expo-image": "~2.3.2",
    "expo-router": "^5.1.3",
    "expo-secure-store": "~14.2.3",
    "react-native": "^0.80.1",
    "react-native-gesture-handler": "^2.27.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@babel/core": "^7.28.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.57.0",
    "eslint-config-expo": "^7.1.2",
    "prettier": "^3.2.5",
    "expo-blur": "^14.1.5",
    "react": "^19.1.0",
    "react-native-reanimated": "^3.18.0",
    "react-native-svg": "^15.12.0",
    "typescript": "^5.8.3",
    "@types/react": "^19.1.8",
    "@types/react-native": "^0.73.0"
  }
}
